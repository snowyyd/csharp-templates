{
  "$schema": "https://json.schemastore.org/template.json",
  "author": "snowyyd",
  "identity": "Snowyyd.CsTemplate",
  "name": "snowyyd's C# Template",
  "shortName": "snowyyd.cs",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "classifications": [
    "Solution",
    "Custom"
  ],
  "preferNameDirectory": true,
  "sourceName": "MyTemplate",
  "sources": [
    {
      "exclude": [
        ".template.config/**"
      ]
    }
  ],
  "symbols": {
    "solutionName": {
      "type": "parameter",
      "datatype": "string",
      "fileRename": "MySolution",
      "defaultValue": "MySolution"
    },
    "licenseHolder": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "LICENSE_HOLDER",
      "defaultValue": "snowyyd"
    }
  }
}
